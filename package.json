{
  "name": "cart-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "volta": {
    "node": "20.18.0",
    "npm": "10.9.2"
  },
  "scripts": {
    "dev":       "lerna run dev --parallel",
    "build":     "lerna run build",
    "start":     "lerna run start --parallel",
    "lint":      "lerna run lint",
    "clean":     "lerna run clean && rm -rf node_modules",
    "dev:web":   "lerna run dev --scope=@cart-monorepo/web",
    "dev:api":   "lerna run dev --scope=@cart-monorepo/api",
    "build:web": "lerna run build --scope=@cart-monorepo/web",
    "build:api": "lerna run build --scope=@cart-monorepo/api"
  },
  "devDependencies": {
    "lerna": "^8.1.0"
  }
}